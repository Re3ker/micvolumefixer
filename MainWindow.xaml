<Window x:Class="MicVolumeFixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        Title="MicVolumeFixer"
        Width="460" Height="530"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#16161E"
        Foreground="#F0F0FA"
        FontFamily="Segoe UI"
        FontSize="12.67"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Dark ComboBox Toggle Button -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="#20202C" BorderBrush="#37374B"
                        BorderThickness="1" CornerRadius="2"/>
                <Path x:Name="Arrow" Grid.Column="1"
                      Data="M 0 0 L 4 4 L 8 0 Z"
                      Fill="#9696AF" HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#28283A"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Dark ComboBox Style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F0F0FA"/>
            <Setter Property="Background" Value="#20202C"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggle}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,24,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#20202C"
                                            BorderBrush="#37374B"
                                            BorderThickness="1" CornerRadius="2"/>
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F0F0FA"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#38688C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#38688C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider thumb + track style (dark theme) -->
        <Style x:Key="SliderRepeatButtonLeft" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="IsTabStop" Value="false" />
            <Setter Property="Focusable" Value="false" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="#48C774" CornerRadius="2" Height="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SliderRepeatButtonRight" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="IsTabStop" Value="false" />
            <Setter Property="Focusable" Value="false" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="#37374B" CornerRadius="2" Height="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SliderThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="#48C774" Stroke="#266E40" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButtonLeft}"
                                                  Command="Slider.DecreaseLarge" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButtonRight}"
                                                  Command="Slider.IncreaseLarge" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox style (dark theme) -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F0F0FA"/>
            <Setter Property="FontSize" Value="12.67"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="box" Width="16" Height="16"
                                    BorderBrush="#37374B" BorderThickness="1"
                                    Background="#20202C" CornerRadius="2"
                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                <TextBlock x:Name="check" Text="✓"
                                           Foreground="#48C774" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#48C774"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="Background" Value="#28283A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Tray Icon (invisible UI element, managed by H.NotifyIcon) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="MicVolumeFixer"
                        Visibility="Collapsed"
                        TrayMouseDoubleClick="TrayIcon_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Background="#20202C" BorderBrush="#37374B"
                             Foreground="#F0F0FA">
                    <MenuItem Header="Show MicVolumeFixer" FontWeight="Bold"
                              Click="TrayShow_Click"/>
                    <Separator Background="#37374B"/>
                    <MenuItem Header="Exit" Click="TrayExit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <StackPanel>
            <!-- Title Banner -->
            <Border Background="#20202C" Height="56">
                <TextBlock Text="●  MicVolumeFixer"
                           FontSize="21.3" FontWeight="Bold"
                           Foreground="#63B3ED"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <StackPanel Margin="24,14,24,0">
                <!-- Device Label + ComboBox -->
                <TextBlock Text="Microphone Device"
                           FontSize="10.67" Foreground="#9696AF"
                           Margin="0,0,0,4"/>
                <ComboBox x:Name="cboDevices" Height="30"
                          Style="{StaticResource DarkComboBox}"
                          FontSize="12.67"
                          SelectionChanged="CboDevices_SelectionChanged"/>

                <!-- Current Volume -->
                <TextBlock Text="Current Volume"
                           FontSize="10.67" Foreground="#9696AF"
                           Margin="0,18,0,4"/>
                <Grid Height="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <!-- Custom gradient progress bar -->
                    <Border Grid.Column="0" BorderBrush="#37374B"
                            BorderThickness="1" CornerRadius="2"
                            Background="#2D2D3C" ClipToBounds="True">
                        <Border x:Name="pbCurrentVol" HorizontalAlignment="Left"
                                Width="0" CornerRadius="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#78C8FF" Offset="0"/>
                                    <GradientStop Color="#63B3ED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                    <TextBlock x:Name="lblCurrentVol" Grid.Column="1"
                               Text="– %" FontSize="29.3" FontWeight="Bold"
                               Foreground="#63B3ED"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Target Volume -->
                <TextBlock Text="Target Volume"
                           FontSize="10.67" Foreground="#9696AF"
                           Margin="0,18,0,4"/>
                <Grid Height="36">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="sliderTarget" Grid.Column="0"
                            Style="{StaticResource DarkSlider}"
                            Minimum="0" Maximum="100" Value="90"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            SmallChange="1" LargeChange="5"
                            VerticalAlignment="Center"
                            ValueChanged="SliderTarget_ValueChanged"/>
                    <TextBlock x:Name="lblTargetVal" Grid.Column="1"
                               Text="90 %" FontSize="29.3" FontWeight="Bold"
                               Foreground="#48C774"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Toggle Button -->
                <Button x:Name="btnToggle" Height="48"
                        Content="▶  Start Monitoring"
                        FontSize="14.67" FontWeight="Bold"
                        Foreground="#F0F0FA" Background="#303042"
                        BorderThickness="0" Cursor="Hand"
                        Margin="0,16,0,0"
                        Click="BtnToggle_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Status Label -->
                <Border Background="#20202C" CornerRadius="2"
                        Height="26" Margin="0,12,0,0">
                    <TextBlock x:Name="lblStatus" Text="Idle"
                               FontSize="11.3" FontStyle="Italic"
                               Foreground="#9696AF"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Settings Group -->
                <Border Background="#20202C" CornerRadius="4"
                        BorderBrush="#37374B" BorderThickness="1"
                        Margin="0,16,0,0" Padding="14,8,14,12">
                    <StackPanel>
                        <TextBlock Text="Settings" FontSize="12.67"
                                   FontWeight="Bold" Foreground="#9696AF"
                                   Margin="0,0,0,8"/>
                        <CheckBox x:Name="cbMinimizeToTray"
                                  Content="Minimize to system tray on close"
                                  Style="{StaticResource DarkCheckBox}"
                                  Checked="CbMinimizeToTray_Changed"
                                  Unchecked="CbMinimizeToTray_Changed"
                                  Margin="0,0,0,8"/>
                        <CheckBox x:Name="cbAutostart"
                                  Content="Start with Windows (minimized to tray)"
                                  Style="{StaticResource DarkCheckBox}"
                                  Checked="CbAutostart_Changed"
                                  Unchecked="CbAutostart_Changed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
