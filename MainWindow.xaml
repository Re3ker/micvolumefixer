<Window x:Class="MicVolumeFixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        xmlns:local="clr-namespace:MicVolumeFixer"
        Title="MicVolumeFixer"
        Width="480" Height="570"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="12.67"
        Foreground="#E8E8F8"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Title bar button style -->
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#8888A0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2E2E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ScrollBar style for ComboBox dropdown -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#1E1E2E" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="OverridesDefaultStyle" Value="True"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border x:Name="tb" Background="#3A3A50"
                                                                    CornerRadius="4" Margin="1"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="tb" Property="Background" Value="#505068"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button style (red hover) -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C53030"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox Toggle Button -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="24"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="#1E1E2E" BorderBrush="#2A2A3C"
                        BorderThickness="1" CornerRadius="6"/>
                <Path x:Name="Arrow" Grid.Column="1"
                      Data="M 0 0 L 4 4 L 8 0 Z"
                      Fill="#8888A0" HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#2E2E42"/>
                    <Setter TargetName="Border" Property="BorderBrush" Value="#3A3A50"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Dark ComboBox Style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E8E8F8"/>
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggle}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,3,28,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#1E1E2E"
                                            BorderBrush="#2A2A3C"
                                            BorderThickness="1" CornerRadius="6"
                                            Margin="0,2,0,0"/>
                                    <ScrollViewer Margin="2,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E8E8F8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4"
                                Margin="2,0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E4A6E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E4A6E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox style -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8E8F8"/>
            <Setter Property="FontSize" Value="12.67"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="box" Width="18" Height="18"
                                    BorderBrush="#2A2A3C" BorderThickness="1.5"
                                    Background="#1E1E2E" CornerRadius="4"
                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                <TextBlock x:Name="check" Text="✓"
                                           Foreground="#48C774" FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#48C774"/>
                                <Setter TargetName="box" Property="Background" Value="#1A2E22"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="Background" Value="#2E2E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Modern ContextMenu style -->
        <Style TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#1A1A26" BorderBrush="#2A2A3C"
                                BorderThickness="1" CornerRadius="8"
                                Padding="4,6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                                  Opacity="0.5" Color="#000000"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern MenuItem style -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#E8E8F8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12.67"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="4" Margin="2,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Separator style -->
        <Style TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="#2A2A3C" Height="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border with shadow & rounded corners -->
    <Border Background="#13131B" CornerRadius="12" Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="2" Opacity="0.55"
                              Color="#000000"/>
        </Border.Effect>
        <Border CornerRadius="12" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tray Icon -->
                <tb:TaskbarIcon x:Name="TrayIcon"
                                ToolTipText="MicVolumeFixer"
                                Visibility="Collapsed"
                                TrayMouseDoubleClick="TrayIcon_DoubleClick">
                    <tb:TaskbarIcon.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Show MicVolumeFixer" FontWeight="SemiBold"
                                      Click="TrayShow_Click"/>
                            <Separator/>
                            <MenuItem Header="Exit" Click="TrayExit_Click"/>
                        </ContextMenu>
                    </tb:TaskbarIcon.ContextMenu>
                </tb:TaskbarIcon>

                <!-- Custom Title Bar -->
                <Border Grid.Row="0" Background="#1A1A26" Padding="16,10"
                        CornerRadius="12,12,0,0"
                        MouseDown="TitleBar_MouseDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="#63B3ED"
                                     Margin="0,0,10,0"/>
                            <TextBlock Text="MicVolumeFixer" FontSize="15"
                                       FontWeight="SemiBold" Foreground="#E0E0F0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="─" Style="{StaticResource TitleBarBtn}"
                                    Click="MinimizeBtn_Click"/>
                            <Button Content="✕" Style="{StaticResource CloseBtn}"
                                    Margin="4,0,0,0"
                                    Click="CloseBtn_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,14,24,18">
                        <!-- MICROPHONE DEVICE -->
                        <TextBlock Text="MICROPHONE DEVICE"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#6868A0"
                                   Margin="0,0,0,6"/>
                        <ComboBox x:Name="cboDevices" Height="34"
                                  Style="{StaticResource DarkComboBox}"
                                  FontSize="12.67"
                                  SelectionChanged="CboDevices_SelectionChanged"/>

                        <!-- VOLUME KNOB -->
                        <local:VolumeKnob x:Name="volumeKnob"
                                          HorizontalAlignment="Center"
                                          Margin="0,6,0,-12"
                                          TargetVolumeChanged="VolumeKnob_TargetVolumeChanged"/>

                        <!-- Toggle Button -->
                        <Button x:Name="btnToggle" Height="48"
                                Content="▶  Start Monitoring"
                                FontSize="14.67" FontWeight="Bold"
                                Foreground="#E8E8F8" Background="#1E1E2E"
                                BorderThickness="0" Cursor="Hand"
                                Margin="0,12,0,0"
                                Click="BtnToggle_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="8" BorderBrush="#2A2A3C"
                                                        BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Status -->
                        <Border Background="#1A1A26" CornerRadius="6"
                                Height="28" Margin="0,10,0,0"
                                BorderBrush="#2A2A3C" BorderThickness="1">
                            <TextBlock x:Name="lblStatus" Text="Idle"
                                       FontSize="11.3" FontStyle="Italic"
                                       Foreground="#8888A0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- SETTINGS -->
                        <TextBlock Text="SETTINGS"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="#6868A0"
                                   Margin="0,14,0,6"/>
                        <Border Background="#1A1A26" CornerRadius="8"
                                BorderBrush="#2A2A3C" BorderThickness="1"
                                Padding="16,12,16,14">
                            <StackPanel>
                                <CheckBox x:Name="cbMinimizeToTray"
                                          Content="Minimize to system tray on close"
                                          Style="{StaticResource DarkCheckBox}"
                                          Checked="CbMinimizeToTray_Changed"
                                          Unchecked="CbMinimizeToTray_Changed"
                                          Margin="0,0,0,10"/>
                                <CheckBox x:Name="cbAutostart"
                                          Content="Start with Windows (minimized to tray)"
                                          Style="{StaticResource DarkCheckBox}"
                                          Checked="CbAutostart_Changed"
                                          Unchecked="CbAutostart_Changed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
</Window>
